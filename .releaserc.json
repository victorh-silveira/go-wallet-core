{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "style", "release": "patch" },
          { "type": "docs", "release": "patch" },
          { "type": "build", "release": "patch" },
          { "type": "ci", "release": "patch" },
          { "type": "revert", "release": "patch" },
          { "type": "test", "release": "patch" },
          { "type": "chore", "release": "patch" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "🚀 Nova Funcionalidade", "hidden": false },
            { "type": "fix", "section": "🐛 Correções de Erros", "hidden": false },
            { "type": "perf", "section": "⚡ Melhorias de Performance", "hidden": false },
            { "type": "refactor", "section": "🛠️ Refatorações de Código", "hidden": false },
            { "type": "docs", "section": "📖 Documentação", "hidden": false },
            { "type": "style", "section": "💅 Estilo e Formatação", "hidden": false },
            { "type": "test", "section": "🧪 Testes e Qualidade", "hidden": false },
            { "type": "build", "section": "📦 Build e Dependências", "hidden": false },
            { "type": "ci", "section": "👷 Integração Contínua (CI/CD)", "hidden": false },
            { "type": "revert", "section": "⏪ Reversões", "hidden": false },
            { "type": "chore", "section": "🧹 Manutenção e Configurações", "hidden": false },
            { "type": "breaking", "section": "💥 MUDANÇAS QUEBRANTES (BREAKING)", "hidden": false }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "go mod tidy"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["go.mod", "go.sum", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
